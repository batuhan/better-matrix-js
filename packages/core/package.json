{
  "name": "better-matrix-js",
  "version": "0.1.0",
  "description": "WASM-backed TypeScript Matrix SDK built on mautrix-go",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "import": "./dist/cloudflare.js"
    },
    "./matrix-core.wasm": "./dist/matrix-core.wasm",
    "./wasm_exec.js": "./dist/wasm_exec.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npm run build:wasm",
    "build:wasm": "mkdir -p dist && cd native && GOOS=js GOARCH=wasm CGO_ENABLED=0 go build -tags goolm -ldflags='-s -w' -o ../dist/matrix-core.wasm ./cmd/matrix-wasm && cp \"$(go env GOROOT)/lib/wasm/wasm_exec.js\" ../dist/wasm_exec.js",
    "clean": "rm -rf dist",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "matrix",
    "mautrix",
    "wasm",
    "chat-sdk"
  ],
  "license": "MPL-2.0"
}
